# Discord Bot Deployment Environment Variables
# Copy this to .env and fill in your actual values

# ========== REQUIRED ==========
# Get these from Discord Developer Portal: https://discord.com/developers/applications

# Your bot's token
DISCORD_TOKEN=your_bot_token_here

# Your application ID
APPLICATION_ID=your_application_id_here

# Your Discord user ID (for owner-only commands)
OWNER_ID=your_discord_user_id_here

# ========== OPTIONAL ==========
# Guild ID for faster command sync (leave empty for global commands)
GUILD_ID=

# ========== DASHBOARD ==========
# Enable or disable the web dashboard
ENABLE_DASHBOARD=true

# Secret key for dashboard sessions (change this to a secure random string)
# Generate with: openssl rand -base64 32
DASHBOARD_SECRET=change_this_to_a_random_secret_key

# ========== LOGGING ==========
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ========== AI/API KEYS (Optional) ==========
# For the /ask command - choose either OpenAI or Google Gemini

# OpenAI API Key (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your_key_here

# Google Gemini API Key (https://ai.google.dev)
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-1.5-flash

# ========== WEATHER ==========
# OpenWeather API Key for /weather command
# Get free key from: https://openweathermap.org/api
# OPENWEATHER_API_KEY=your_openweather_key_here
