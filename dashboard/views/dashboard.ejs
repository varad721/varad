<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Advanced Discord Bot</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #36393f;
            color: #dcddde;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .navbar {
            background: #2f3136;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #202225;
        }
        .navbar h1 {
            color: #5865F2;
            font-size: 24px;
        }
        .navbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
        }
        .logout-btn {
            background: #f04747;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
        }
        .logout-btn:hover {
            background: #d84040;
        }
        .container {
            max-width: 1400px;
            margin: 30px auto;
            padding: 0 20px;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: #2f3136;
            border: 1px solid #202225;
            border-radius: 6px;
            padding: 20px;
            text-align: center;
        }
        .stat-card h3 {
            color: #b9bbbe;
            font-size: 12px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }
        .stat-card .value {
            font-size: 32px;
            color: #5865F2;
            font-weight: bold;
        }
        .card {
            background: #2f3136;
            border: 1px solid #202225;
            border-radius: 6px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .card h2 {
            margin-bottom: 15px;
            color: #5865F2;
        }
        .info-text {
            color: #b9bbbe;
            font-size: 14px;
            line-height: 1.6;
        }
        .welcome {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 6px;
            padding: 20px;
            margin-bottom: 30px;
        }
        .welcome h1 {
            font-size: 28px;
            margin-bottom: 10px;
        }
        .welcome p {
            opacity: 0.9;
        }
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .tab {
            background: #2f3136;
            border: 1px solid #202225;
            color: #dcddde;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .tab:hover {
            background: #393c43;
        }
        .tab.active {
            background: #5865F2;
            border-color: #5865F2;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #b9bbbe;
        }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 10px;
            background: #202225;
            border: 1px solid #40444b;
            border-radius: 4px;
            color: #dcddde;
            font-size: 14px;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            outline: none;
            border-color: #5865F2;
        }
        .btn {
            background: #5865F2;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
        }
        .btn:hover {
            background: #4752c4;
        }
        .btn-danger {
            background: #f04747;
        }
        .btn-danger:hover {
            background: #d84040;
        }
        .btn-success {
            background: #3ba55c;
        }
        .btn-success:hover {
            background: #2d7d46;
        }
        .table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }
        .table th, .table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #202225;
        }
        .table th {
            color: #b9bbbe;
            font-size: 12px;
            text-transform: uppercase;
        }
        .table tr:hover {
            background: #393c43;
        }
        .guild-selector {
            margin-bottom: 20px;
        }
        .guild-selector select {
            width: 100%;
            max-width: 400px;
            padding: 10px;
            background: #202225;
            border: 1px solid #40444b;
            border-radius: 4px;
            color: #dcddde;
            font-size: 14px;
        }
        .item-list {
            display: grid;
            gap: 10px;
        }
        .item {
            background: #202225;
            padding: 15px;
            border-radius: 4px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .item-info h4 {
            color: #dcddde;
            margin-bottom: 5px;
        }
        .item-info p {
            color: #b9bbbe;
            font-size: 12px;
        }
        .item-actions {
            display: flex;
            gap: 10px;
        }
        .badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
        }
        .badge-success {
            background: #3ba55c;
            color: white;
        }
        .badge-danger {
            background: #f04747;
            color: white;
        }
        .badge-warning {
            background: #faa61a;
            color: white;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <h1>🤖 Bot Dashboard</h1>
        <div class="navbar-right">
            <div class="user-info">
                <span>Owner</span>
            </div>
            <button class="logout-btn" onclick="logout()">Logout</button>
        </div>
    </div>

    <div class="container">
        <div class="welcome">
            <h1>Welcome to the Dashboard! 👋</h1>
            <p>Manage your Discord Bot with full control over leveling, economy, moderation, and more.</p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Connected Guilds</h3>
                <div class="value" id="stat-guilds">-</div>
            </div>
            <div class="stat-card">
                <h3>Total Users</h3>
                <div class="value" id="stat-users">-</div>
            </div>
            <div class="stat-card">
                <h3>Total Warnings</h3>
                <div class="value" id="stat-warnings">-</div>
            </div>
            <div class="stat-card">
                <h3>Mod Logs</h3>
                <div class="value" id="stat-modlogs">-</div>
            </div>
        </div>

        <div class="guild-selector">
            <label>Select Server:</label>
            <select id="guild-select" onchange="loadGuildData()">
                <option value="">Loading servers...</option>
            </select>
        </div>

        <div class="tabs">
            <div class="tab active" onclick="switchTab('overview')">Overview</div>
            <div class="tab" onclick="switchTab('leveling')">Leveling</div>
            <div class="tab" onclick="switchTab('economy')">Economy</div>
            <div class="tab" onclick="switchTab('shop')">Shop</div>
            <div class="tab" onclick="switchTab('custom-commands')">Custom Commands</div>
            <div class="tab" onclick="switchTab('settings')">Settings</div>
        </div>

        <div id="tab-overview" class="tab-content active">
            <div class="card">
                <h2>📊 Server Statistics</h2>
                <div id="server-stats" class="stats-grid">
                    <div class="stat-card">
                        <h3>XP Leaderboard</h3>
                        <div class="value" id="leaderboard-count">-</div>
                    </div>
                    <div class="stat-card">
                        <h3>Economy Balance</h3>
                        <div class="value" id="economy-count">-</div>
                    </div>
                    <div class="stat-card">
                        <h3>Custom Commands</h3>
                        <div class="value" id="commands-count">-</div>
                    </div>
                    <div class="stat-card">
                        <h3>Shop Items</h3>
                        <div class="value" id="shop-count">-</div>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-leveling" class="tab-content">
            <div class="card">
                <h2>📊 Leveling System</h2>
                <div class="form-group">
                    <label>XP Multiplier (1-10)</label>
                    <input type="number" id="xp-multiplier" min="1" max="10" value="1">
                </div>
                <div class="form-group">
                    <label><input type="checkbox" id="leveling-enabled" checked> Enable Leveling</label>
                </div>
                <button class="btn" onclick="saveLevelingSettings()">Save Settings</button>
            </div>
            <div class="card">
                <h2>🏆 Level Rewards</h2>
                <div class="form-group" style="display: flex; gap: 10px; align-items: flex-end;">
                    <div style="flex: 1;">
                        <label>Level</label>
                        <input type="number" id="reward-level" min="1">
                    </div>
                    <div style="flex: 1;">
                        <label>Role ID</label>
                        <input type="text" id="reward-role">
                    </div>
                    <button class="btn" onclick="addLevelReward()">Add Reward</button>
                </div>
                <div id="level-rewards-list" class="item-list"></div>
            </div>
            <div class="card">
                <h2>🏅 XP Leaderboard</h2>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>User ID</th>
                            <th>Level</th>
                            <th>XP</th>
                        </tr>
                    </thead>
                    <tbody id="leaderboard-table"></tbody>
                </table>
            </div>
        </div>

        <div id="tab-economy" class="tab-content">
            <div class="card">
                <h2>💰 Economy Leaderboard</h2>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>User ID</th>
                            <th>Balance</th>
                        </tr>
                    </thead>
                    <tbody id="economy-table"></tbody>
                </table>
            </div>
        </div>

        <div id="tab-shop" class="tab-content">
            <div class="card">
                <h2>🏪 Shop Management</h2>
                <div class="form-group">
                    <label>Item Name</label>
                    <input type="text" id="shop-name">
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea id="shop-description" rows="2"></textarea>
                </div>
                <div class="form-group">
                    <label>Price (coins)</label>
                    <input type="number" id="shop-price" min="0">
                </div>
                <div class="form-group">
                    <label>Role ID (optional)</label>
                    <input type="text" id="shop-role">
                </div>
                <button class="btn" onclick="addShopItem()">Add Item</button>
            </div>
            <div class="card">
                <h2>📦 Shop Items</h2>
                <div id="shop-list" class="item-list"></div>
            </div>
        </div>

        <div id="tab-custom-commands" class="tab-content">
            <div class="card">
                <h2>📝 Custom Commands</h2>
                <div class="form-group">
                    <label>Command Name</label>
                    <input type="text" id="cmd-name">
                </div>
                <div class="form-group">
                    <label>Response</label>
                    <textarea id="cmd-response" rows="3"></textarea>
                </div>
                <button class="btn" onclick="addCustomCommand()">Add Command</button>
            </div>
            <div class="card">
                <h2>📋 Custom Commands List</h2>
                <div id="commands-list" class="item-list"></div>
            </div>
        </div>

        <div id="tab-settings" class="tab-content">
            <div class="card">
                <h2>⚙️ Server Settings</h2>
                <div class="form-group">
                    <label>Prefix</label>
                    <input type="text" id="setting-prefix" value="!">
                </div>
                <div class="form-group">
                    <label><input type="checkbox" id="setting-automod" checked> Enable Auto-Moderation</label>
                </div>
                <div class="form-group">
                    <label>Spam Threshold (messages)</label>
                    <input type="number" id="setting-spam" min="1" max="20" value="5">
                </div>
                <div class="form-group">
                    <label>Starboard Channel ID</label>
                    <input type="text" id="setting-starboard-channel">
                </div>
                <div class="form-group">
                    <label>Starboard Threshold</label>
                    <input type="number" id="setting-starboard-threshold" min="1" max="10" value="3">
                </div>
                <div class="form-group">
                    <label>Welcome Channel ID</label>
                    <input type="text" id="setting-welcome-channel">
                </div>
                <div class="form-group">
                    <label>Level Channel ID</label>
                    <input type="text" id="setting-level-channel">
                </div>
                <button class="btn" onclick="saveSettings()">Save Settings</button>
            </div>
            <div class="card">
                <h2>🛡️ Bypass Users</h2>
                <div class="form-group" style="display: flex; gap: 10px; align-items: flex-end;">
                    <div style="flex: 1;">
                        <label>User ID</label>
                        <input type="text" id="bypass-user">
                    </div>
                    <div style="flex: 1;">
                        <label>Reason</label>
                        <input type="text" id="bypass-reason">
                    </div>
                    <button class="btn" onclick="addBypassUser()">Add Bypass</button>
                </div>
                <div id="bypass-list" class="item-list"></div>
            </div>
        </div>
    </div>

    <script>
        let currentGuildId = null;

        function logout() {
            fetch('/api/logout', { method: 'POST' })
                .then(() => window.location.href = '/login')
                .catch(err => console.error('Logout failed:', err));
        }

        function switchTab(tabName) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelector(`.tab[onclick="switchTab('${tabName}')"]`).classList.add('active');
            document.getElementById(`tab-${tabName}`).classList.add('active');
        }

        async function loadStats() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                if (data.status === 'success') {
                    document.getElementById('stat-guilds').textContent = data.guilds || 0;
                    document.getElementById('stat-users').textContent = data.users || 0;
                    document.getElementById('stat-warnings').textContent = data.warnings || 0;
                    document.getElementById('stat-modlogs').textContent = data.modlogs || 0;
                }
            } catch (e) {
                console.error('Failed to load stats:', e);
            }
        }

        async function loadGuilds() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                if (data.status === 'success' && data.guildList) {
                    const select = document.getElementById('guild-select');
                    select.innerHTML = '<option value="">Select a server...</option>';
                    data.guildList.forEach(guild => {
                        select.innerHTML += `<option value="${guild.id}">${guild.name}</option>`;
                    });
                }
            } catch (e) {
                console.error('Failed to load guilds:', e);
            }
        }

        async function loadGuildData() {
            currentGuildId = document.getElementById('guild-select').value;
            if (!currentGuildId) return;

            try {
                const res = await fetch(`/api/guild-settings/${currentGuildId}`);
                const data = await res.json();
                if (data.status === 'success') {
                    document.getElementById('xp-multiplier').value = data.xp_multiplier || 1;
                    document.getElementById('leveling-enabled').checked = data.leveling_enabled !== 0;
                    document.getElementById('setting-prefix').value = data.prefix || '!';
                    document.getElementById('setting-automod').checked = data.auto_mod_enabled !== 0;
                    document.getElementById('setting-spam').value = data.spam_threshold || 5;
                    document.getElementById('setting-starboard-channel').value = data.starboard_channel || '';
                    document.getElementById('setting-starboard-threshold').value = data.starboard_threshold || 3;
                    document.getElementById('setting-welcome-channel').value = data.welcome_channel || '';
                    document.getElementById('setting-level-channel').value = data.level_channel || '';
                }
            } catch (e) {
                console.error('Failed to load guild settings:', e);
            }

            loadLeaderboard();
            loadEconomyLeaderboard();
            loadLevelRewards();
            loadShopItems();
            loadCustomCommands();
            loadBypassUsers();
        }

        async function loadLeaderboard() {
            try {
                const res = await fetch(`/api/leaderboard/${currentGuildId}`);
                const data = await res.json();
                if (data.status === 'success') {
                    document.getElementById('leaderboard-count').textContent = data.leaderboard.length;
                    const tbody = document.getElementById('leaderboard-table');
                    tbody.innerHTML = data.leaderboard.map((entry, i) => `
                        <tr>
                            <td>${i + 1}</td>
                            <td>${entry.user_id}</td>
                            <td>${entry.level}</td>
                            <td>${entry.xp}</td>
                        </tr>
                    `).join('');
                }
            } catch (e) {
                console.error('Failed to load leaderboard:', e);
            }
        }

        async function loadEconomyLeaderboard() {
            try {
                const res = await fetch(`/api/economy-leaderboard/${currentGuildId}`);
                const data = await res.json();
                if (data.status === 'success') {
                    document.getElementById('economy-count').textContent = data.leaderboard.length;
                    const tbody = document.getElementById('economy-table');
                    tbody.innerHTML = data.leaderboard.map((entry, i) => `
                        <tr>
                            <td>${i + 1}</td>
                            <td>${entry.user_id}</td>
                            <td>${entry.balance.toLocaleString()}</td>
                        </tr>
                    `).join('');
                }
            } catch (e) {
                console.error('Failed to load economy leaderboard:', e);
            }
        }

        async function loadLevelRewards() {
            try {
                const res = await fetch(`/api/level-rewards/${currentGuildId}`);
                const data = await res.json();
                if (data.status === 'success') {
                    const list = document.getElementById('level-rewards-list');
                    list.innerHTML = data.rewards.map(r => `
                        <div class="item">
                            <div class="item-info">
                                <h4>Level ${r.level}</h4>
                                <p>Role: ${r.role_id}</p>
                            </div>
                            <button class="btn btn-danger" onclick="removeLevelReward(${r.level})">Remove</button>
                        </div>
                    `).join('');
                }
            } catch (e) {
                console.error('Failed to load level rewards:', e);
            }
        }

        async function loadShopItems() {
            try {
                const res = await fetch(`/api/shop/${currentGuildId}`);
                const data = await res.json();
                if (data.status === 'success') {
                    document.getElementById('shop-count').textContent = data.items.length;
                    const list = document.getElementById('shop-list');
                    list.innerHTML = data.items.map(item => `
                        <div class="item">
                            <div class="item-info">
                                <h4>${item.name}</h4>
                                <p>${item.description || 'No description'} - ${item.price} coins</p>
                            </div>
                            <button class="btn btn-danger" onclick="removeShopItem('${item.name}')">Remove</button>
                        </div>
                    `).join('');
                }
            } catch (e) {
                console.error('Failed to load shop items:', e);
            }
        }

        async function loadCustomCommands() {
            try {
                const res = await fetch(`/api/custom-commands/${currentGuildId}`);
                const data = await res.json();
                if (data.status === 'success') {
                    document.getElementById('commands-count').textContent = data.commands.length;
                    const list = document.getElementById('commands-list');
                    list.innerHTML = data.commands.map(cmd => `
                        <div class="item">
                            <div class="item-info">
                                <h4>/${cmd.name}</h4>
                                <p>${cmd.response.substring(0, 50)}...</p>
                            </div>
                            <button class="btn btn-danger" onclick="removeCustomCommand('${cmd.name}')">Remove</button>
                        </div>
                    `).join('');
                }
            } catch (e) {
                console.error('Failed to load custom commands:', e);
            }
        }

        async function loadBypassUsers() {
            try {
                const res = await fetch(`/api/bypass-users/${currentGuildId}`);
                const data = await res.json();
                if (data.status === 'success') {
                    const list = document.getElementById('bypass-list');
                    list.innerHTML = data.users.map(u => `
                        <div class="item">
                            <div class="item-info">
                                <h4>${u.user_id}</h4>
                                <p>${u.reason || 'No reason'}</p>
                            </div>
                            <button class="btn btn-danger" onclick="removeBypassUser(${u.user_id})">Remove</button>
                        </div>
                    `).join('');
                }
            } catch (e) {
                console.error('Failed to load bypass users:', e);
            }
        }

        async function saveLevelingSettings() {
            try {
                await fetch(`/api/guild-settings/${currentGuildId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        xp_multiplier: parseInt(document.getElementById('xp-multiplier').value),
                        leveling_enabled: document.getElementById('leveling-enabled').checked ? 1 : 0
                    })
                });
                alert('Leveling settings saved!');
            } catch (e) {
                alert('Failed to save settings');
            }
        }

        async function addLevelReward() {
            const level = document.getElementById('reward-level').value;
            const roleId = document.getElementById('reward-role').value;
            if (!level || !roleId) return alert('Please fill all fields');
            
            try {
                await fetch(`/api/level-rewards/${currentGuildId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ level: parseInt(level), role_id: roleId })
                });
                loadLevelRewards();
                document.getElementById('reward-level').value = '';
                document.getElementById('reward-role').value = '';
            } catch (e) {
                alert('Failed to add reward');
            }
        }

        async function removeLevelReward(level) {
            try {
                await fetch(`/api/level-rewards/${currentGuildId}/${level}`, { method: 'DELETE' });
                loadLevelRewards();
            } catch (e) {
                alert('Failed to remove reward');
            }
        }

        async function addShopItem() {
            const name = document.getElementById('shop-name').value;
            const description = document.getElementById('shop-description').value;
            const price = document.getElementById('shop-price').value;
            const roleId = document.getElementById('shop-role').value;
            
            if (!name || !price) return alert('Name and price are required');
            
            try {
                await fetch(`/api/shop/${currentGuildId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, description, price: parseInt(price), role_id: roleId || null })
                });
                loadShopItems();
                document.getElementById('shop-name').value = '';
                document.getElementById('shop-description').value = '';
                document.getElementById('shop-price').value = '';
                document.getElementById('shop-role').value = '';
            } catch (e) {
                alert('Failed to add item');
            }
        }

        async function removeShopItem(name) {
            try {
                await fetch(`/api/shop/${currentGuildId}/${encodeURIComponent(name)}`, { method: 'DELETE' });
                loadShopItems();
            } catch (e) {
                alert('Failed to remove item');
            }
        }

        async function addCustomCommand() {
            const name = document.getElementById('cmd-name').value;
            const response = document.getElementById('cmd-response').value;
            
            if (!name || !response) return alert('Name and response are required');
            
            try {
                await fetch(`/api/custom-commands/${currentGuildId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, response })
                });
                loadCustomCommands();
                document.getElementById('cmd-name').value = '';
                document.getElementById('cmd-response').value = '';
            } catch (e) {
                alert('Failed to add command');
            }
        }

        async function removeCustomCommand(name) {
            try {
                await fetch(`/api/custom-commands/${currentGuildId}/${encodeURIComponent(name)}`, { method: 'DELETE' });
                loadCustomCommands();
            } catch (e) {
                alert('Failed to remove command');
            }
        }

        async function saveSettings() {
            try {
                await fetch(`/api/guild-settings/${currentGuildId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        prefix: document.getElementById('setting-prefix').value,
                        auto_mod_enabled: document.getElementById('setting-automod').checked ? 1 : 0,
                        spam_threshold: parseInt(document.getElementById('setting-spam').value),
                        starboard_channel: document.getElementById('setting-starboard-channel').value || null,
                        starboard_threshold: parseInt(document.getElementById('setting-starboard-threshold').value),
                        welcome_channel: document.getElementById('setting-welcome-channel').value || null,
                        level_channel: document.getElementById('setting-level-channel').value || null
                    })
                });
                alert('Settings saved!');
            } catch (e) {
                alert('Failed to save settings');
            }
        }

        async function addBypassUser() {
            const userId = document.getElementById('bypass-user').value;
            const reason = document.getElementById('bypass-reason').value;
            
            if (!userId) return alert('User ID is required');
            
            try {
                await fetch(`/api/bypass-users/${currentGuildId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ user_id: userId, reason })
                });
                loadBypassUsers();
                document.getElementById('bypass-user').value = '';
                document.getElementById('bypass-reason').value = '';
            } catch (e) {
                alert('Failed to add bypass user');
            }
        }

        async function removeBypassUser(userId) {
            try {
                await fetch(`/api/bypass-users/${currentGuildId}/${userId}`, { method: 'DELETE' });
                loadBypassUsers();
            } catch (e) {
                alert('Failed to remove bypass user');
            }
        }

        loadStats();
        loadGuilds();
        setInterval(loadStats, 30000);
    </script>
</body>
</html>
