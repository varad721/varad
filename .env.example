# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Application ID (from Discord Developer Portal)
APPLICATION_ID=your_application_id_here

# Your Discord User ID (for owner-only commands & dashboard login)
OWNER_ID=your_discord_user_id_here

# Guild ID for faster command sync (optional)
# If set, commands sync instantly to this guild instead of globally (takes up to 1 hour)
GUILD_ID=

# Database
DATABASE_PATH=data/bot.db

# Dashboard Settings
ENABLE_DASHBOARD=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_SECRET=change_this_to_a_random_secret

# Logging
LOG_LEVEL=INFO

# Optional: OpenAI API Key (for /ask command)
# OPENAI_API_KEY=sk-your_key_here

# Optional: Google Gemini API Key (for /ask command - preferred)
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-1.5-flash
